<% const ogImage = section.image.startsWith("http") ? section.image : `https://www.phavai.com${section.image}`; %>
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= section.metaTitle || `${section.title} Reviews | Phavai` %></title>
  <meta name="description" content="<%= section.metaDescription || section.description %>" />
  <link rel="canonical" href="https://www.phavai.com/<%= section.slug %>.html" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="<%= section.title %> Reviews | Phavai" />
  <meta property="og:description" content="<%= section.description %>" />
  <meta property="og:image" content="<%= ogImage %>" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
  <script type="application/ld+json">
  <%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": `${section.title} Reviews | Phavai`,
    "description": section.description,
    "url": `https://www.phavai.com/${section.slug}.html`,
    "hasPart": reviews.map((review) => ({
      "@type": "Article",
      "headline": review.title,
      "url": `https://www.phavai.com/${review.slug}.html`
    }))
  }, null, 2) %>
  </script>
  <script type="application/ld+json">
  <%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://www.phavai.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": section.title,
        "item": `https://www.phavai.com/${section.slug}.html`
      }
    ]
  }, null, 2) %>
  </script>
</head>
<body>
  <header class="site-header">
    <nav class="nav" aria-label="Primary navigation">
      <a class="brand" href="/index.html"><span class="brand-mark">P</span> Phavai</a>
      <div class="nav-links">
        <% allSections.forEach((item) => { %>
          <a href="/<%= item.slug %>.html"><%= item.title %></a>
        <% }) %>
        <a class="hide-small" href="/methodology.html">Methodology</a>
      </div>
    </nav>
  </header>

  <main>
    <section class="page-hero section-hero">
      <div class="wrap page-grid">
        <div>
          <a class="crumb" href="/index.html">Phavai / <%= section.title %></a>
          <h1><%= section.title %> Reviews</h1>
          <p class="lede"><%= section.intro %></p>
          <div class="meta-row">
            <span class="meta-pill">Buyer-first picks</span>
            <span class="meta-pill"><%= reviews.length %> live buying guides</span>
            <span class="meta-pill">Retail links never buy rank</span>
          </div>
        </div>
        <img class="section-hero-image" src="<%= section.image %>" alt="<%= section.title %> products" width="900" height="720" />
      </div>
    </section>

    <section class="band surface">
      <div class="wrap page-grid">
        <article class="text-panel">
          <h2>What this category covers</h2>
          <p><%= section.description %></p>
          <ul class="plain-list">
            <% section.covered.forEach((item) => { %>
              <li><%= item %></li>
            <% }) %>
          </ul>
        </article>
        <aside class="text-panel">
          <h2>Why this category needs care</h2>
          <p><%= section.trust %></p>
          <p>Every guide keeps the winner, the tradeoffs, and the proof in the same view so you can move faster without buying blind.</p>
          <a class="button secondary" href="/methodology.html">Read the methodology</a>
        </aside>
      </div>
    </section>

    <% if (section.matters?.length) { %>
    <section class="band">
      <div class="wrap">
        <div class="section-head">
          <h2>What matters when you shop <%= section.title %>.</h2>
          <p>The best choice usually comes down to a few practical questions, not a spec sheet arms race.</p>
        </div>
        <div class="signal-grid">
          <% section.matters.forEach((item) => { %>
            <div class="signal">
              <b><%= item.heading %></b>
              <p><%= item.body %></p>
            </div>
          <% }) %>
        </div>
      </div>
    </section>
    <% } %>

    <% if (sourceTrust) { %>
    <section class="band surface">
      <div class="wrap page-grid">
        <article class="text-panel">
          <div class="section-kicker">Source quality</div>
          <h2>What we trust here</h2>
          <p>Phavai favors the best category-specific reviews first, then exact video reviews and owner discussions that reveal real-world tradeoffs.</p>
          <div class="source-pill-list" aria-label="Trusted <%= section.title %> sources">
            <% sourceTrust.trustedPublishers.slice(0, 9).forEach((publisher) => { %>
              <span><%= publisher %></span>
            <% }) %>
          </div>
        </article>
        <aside class="text-panel source-rule-card">
          <h2>Best evidence first</h2>
          <p><strong>Tier 1:</strong> <%= sourceTrust.tierLabels.tier1 %></p>
          <p><strong>Tier 2:</strong> <%= sourceTrust.tierLabels.tier2 %></p>
          <p><strong>Tier 3:</strong> <%= sourceTrust.tierLabels.tier3 %></p>
        </aside>
      </div>
    </section>
    <% } %>

    <section class="band" id="guides">
      <div class="wrap">
        <div class="section-head">
          <h2><%= section.title %> buying guides</h2>
          <p>Choose the guide closest to your real use case. Broad guides help you shortlist; narrow guides help you avoid the wrong compromise.</p>
        </div>
        <div class="category-grid">
          <% reviews.forEach((review) => { %>
            <a class="category-card" href="/<%= review.slug %>.html">
              <img src="<%= review.image || review.products[0].image %>" alt="<%= review.title %>" width="800" height="800" />
              <div class="category-card-body">
                <span class="eyebrow">BestPick guide</span>
                <h3><%= review.title %></h3>
                <p><%= review.description %></p>
              </div>
            </a>
          <% }) %>
        </div>
      </div>
    </section>

    <% if (supportingPages.length) { %>
    <section class="band surface">
      <div class="wrap">
        <div class="section-head">
          <h2>Learn before you compare.</h2>
          <p>These guides explain the choices that make a product right or wrong before price starts doing the talking.</p>
        </div>
        <div class="link-list">
          <% supportingPages.forEach((page) => { %>
            <a href="/<%= page.slug %>.html"><span><%= page.title %></span><span><%= page.type %></span></a>
          <% }) %>
        </div>
      </div>
    </section>
    <% } %>

    <section class="band">
      <div class="wrap">
        <div class="section-head">
          <h2>How Phavai keeps the picks useful.</h2>
          <p>A product can be excellent and still be wrong for you. That is why every guide puts the winner beside fit warnings, owner complaints, and the best reviews behind the pick.</p>
        </div>
        <div class="signal-grid">
          <div class="signal">
            <div class="weight">40</div>
            <b>Expert reviews</b>
            <p>Specialist testing and category expertise set the baseline.</p>
          </div>
          <div class="signal">
            <div class="weight">30</div>
            <b>Creator reviews</b>
            <p>Long-form use reveals fit, setup friction, comfort, and real-world annoyances.</p>
          </div>
          <div class="signal">
            <div class="weight">30</div>
            <b>Owner feedback</b>
            <p>Public discussion catches repeated praise, regrets, and durability complaints.</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="footer-grid">
      <div>Phavai turns crowded product categories into clearer buying decisions.</div>
      <div>
        <a href="/index.html">Home</a>
        <% allSections.forEach((item) => { %>
          <a href="/<%= item.slug %>.html"><%= item.title %></a>
        <% }) %>
        <a href="/methodology.html">Methodology</a>
        <a href="/about.html">About</a>
        <a href="/contact.html">Contact</a>
        <a href="/privacy.html">Privacy</a>
        <a href="/terms.html">Terms</a>
      </div>
    </div>
  </footer>
</body>
</html>
