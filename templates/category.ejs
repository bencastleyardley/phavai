<% const ogImage = products[0].image.startsWith("http") ? products[0].image : `https://www.phavai.com${products[0].image}`; %>
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> | Phavai</title>
  <meta name="description" content="<%= description %>" />
  <link rel="canonical" href="https://www.phavai.com/<%= slug %>.html" />
  <meta property="og:type" content="article" />
  <meta property="og:title" content="<%= title %> | Phavai" />
  <meta property="og:description" content="<%= description %>" />
  <meta property="og:image" content="<%= ogImage %>" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
  <script src="/score-controls.js" defer></script>
  <script type="application/ld+json">
  <%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": schemaName,
    "description": description,
    "itemListElement": products.map((product) => ({
      "@type": "ListItem",
      "position": product.rank,
      "name": product.name,
      "url": `https://www.phavai.com/${slug}.html#${product.name.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "")}`
    }))
  }, null, 2) %>
  </script>
  <% if (faqs?.length) { %>
  <script type="application/ld+json">
  <%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((faq) => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  }, null, 2) %>
  </script>
  <% } %>
</head>
<body>
  <header class="site-header">
    <nav class="nav" aria-label="Primary navigation">
      <a class="brand" href="/index.html"><span class="brand-mark">P</span> Phavai</a>
      <div class="nav-links">
        <% allSections.forEach((item) => { %>
          <a href="/<%= item.slug %>.html"><%= item.title %></a>
        <% }) %>
        <a class="hide-small" href="/methodology.html">Methodology</a>
      </div>
    </nav>
  </header>

  <main>
    <section class="page-hero">
      <div class="wrap">
        <a class="crumb" href="/<%= section.slug %>.html">Phavai / <%= section.title %> / <%= eyebrow %></a>
        <h1><%= title %></h1>
        <p class="lede"><%= description %> Every ranking shows the source mix, consensus, and confidence behind the recommendation.</p>
        <div class="meta-row" aria-label="Page details">
          <span class="meta-pill">Updated <%= updated %></span>
          <span class="meta-pill">Sources verified <%= sourcesVerifiedAt %></span>
          <span class="meta-pill"><%= audience %></span>
          <span class="meta-pill">Affiliate links never affect rank</span>
        </div>
      </div>
    </section>

    <section class="band">
      <div class="wrap ranking-layout">
        <div class="content-column">
          <div data-product-list>
          <% products.forEach((product) => { const id = product.name.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, ""); %>
            <article class="product" id="<%= id %>" data-product-name="<%= product.name %>" data-default-score="<%= product.bestPickScore %>" data-channel-scores='<%- JSON.stringify(Object.fromEntries(product.sourceScores.map((row) => [row.source, row.score]))) %>'>
              <div class="product-media">
                <img src="<%= product.image %>" alt="<%= product.imageAlt || product.name %>" width="500" height="500" loading="<%= product.rank === 1 ? 'eager' : 'lazy' %>" />
              </div>
              <div>
                <span class="rank-badge">Rank <span data-rank>#<%= product.rank %></span></span>
                <h2><%= product.name %></h2>
                <div class="tagline"><%= product.tag %></div>
                <p><%= product.verdict %></p>

                <div class="score-row" aria-label="Phavai score summary for <%= product.name %>">
                  <div class="score-box"><strong><%= product.bestPickScore %></strong><span>Phavai Default</span></div>
                  <div class="score-box"><strong data-bestpick><%= product.bestPickScore %></strong><span>Your Score</span></div>
                  <div class="score-box"><strong data-consensus><%= product.consensus %>%</strong><span>Consensus</span></div>
                  <div class="score-box"><strong><%= product.signal %>/5</strong><span>Signal Strength</span></div>
                </div>
                <p class="score-note">BestPick is calculated from <%= product.evidenceCount %> evidence items rolled into the weighted channel rows below. Your raw weighted score: <span data-raw-score><%= product.rawBestPickScore %></span>/100. Difference from Phavai default: <span data-score-delta>0</span>.</p>

                <div class="product-signal-grid" aria-label="Scoring signals for <%= product.name %>">
                  <% product.sourceScores.forEach((row) => { %>
                    <div class="product-signal">
                      <span><%= row.source %></span>
                      <strong><%= row.score %></strong>
                      <small><%= row.weight %>% signal</small>
                    </div>
                  <% }) %>
                </div>

                <ul class="spec-list" aria-label="Quick specs">
                  <% product.specs.forEach((spec) => { %>
                    <li><%= spec %></li>
                  <% }) %>
                </ul>

                <div class="source-table" aria-label="Score breakdown by source">
                  <% product.sourceScores.forEach((row) => { %>
                    <div class="source-row">
                      <div>
                        <b><%= row.source %></b>
                        <small><%= row.weight %>% category weight</small>
                      </div>
                      <div>
                        <b><%= row.score %>/100</b>
                        <div class="meter" aria-hidden="true"><i style="--value:<%= row.score %>%"></i></div>
                      </div>
                      <div>
                        <b><%= row.tier %></b>
                        <small><%= row.summary %> Top source verified <%= row.topEvidence.verifiedAt %>: <%= row.topEvidence.title || row.topEvidence.sourceName %></small>
                      </div>
                      <% if (row.topEvidence.url) { %>
                        <a href="<%= row.topEvidence.url %>" target="_blank" rel="nofollow noopener">Top source</a>
                      <% } else { %>
                        <span class="source-placeholder">Source pending</span>
                      <% } %>
                    </div>
                  <% }) %>
                </div>

                <details class="evidence-panel">
                  <summary>Show evidence items</summary>
                  <div class="evidence-list">
                    <% product.evidence.forEach((item) => { %>
                      <% if (item.url) { %>
                      <a class="evidence-item" href="<%= item.url %>" target="_blank" rel="nofollow noopener">
                        <span><%= item.channel %> / <%= item.tier %> / <%= item.sourceName %></span>
                        <b><%= item.title || item.sourceName %></b>
                        <small><%= item.score %>/100 - published <%= item.publishedAt %> - verified <%= item.verifiedAt %> - sample <%= item.sampleSize %></small>
                      </a>
                      <% } else { %>
                      <div class="evidence-item">
                        <span><%= item.channel %> / <%= item.tier %> / <%= item.sourceName %></span>
                        <b><%= item.title || item.sourceName %></b>
                        <small><%= item.score %>/100 - published <%= item.publishedAt %> - verified <%= item.verifiedAt %> - sample <%= item.sampleSize %></small>
                      </div>
                      <% } %>
                    <% }) %>
                  </div>
                </details>

                <div class="two-col">
                  <div>
                    <h3>Best for</h3>
                    <p><%= product.bestFor %></p>
                    <h3>Avoid if</h3>
                    <p><%= product.avoidIf %></p>
                  </div>
                  <div>
                    <h3>Pros</h3>
                    <ul class="plain-list">
                      <% product.pros.forEach((pro) => { %><li><%= pro %></li><% }) %>
                    </ul>
                    <h3 style="margin-top:18px">Tradeoffs</h3>
                    <ul class="plain-list">
                      <% product.cons.forEach((con) => { %><li><%= con %></li><% }) %>
                    </ul>
                  </div>
                </div>

                <p class="disclosure"><strong>Price context:</strong> <%= product.price %>. Affiliate links are not active yet. The CTA below preserves the future link structure, and BestPick is calculated before affiliate availability is considered.</p>
                <% if (product.affiliateUrl && product.affiliateUrl !== "#") { %>
                  <a class="button" href="<%= product.affiliateUrl %>" target="_blank" rel="nofollow noopener sponsored">Check price</a>
                <% } else { %>
                  <span class="button disabled" aria-disabled="true">Affiliate link pending</span>
                <% } %>
              </div>
            </article>
          <% }) %>
          </div>

          <section class="comparison-section" aria-labelledby="comparison-heading">
            <div class="section-kicker">Compare quickly</div>
            <h2 id="comparison-heading">Top picks at a glance</h2>
            <p><%= comparisonIntro || "Use this table to compare the ranking, ideal buyer, confidence signals, and tradeoffs before opening the detailed evidence for each product." %></p>
            <div class="comparison-scroll">
              <table class="comparison-table">
                <thead>
                  <tr>
                    <th>Rank</th>
                    <th>Product</th>
                    <th>Best for</th>
                    <th>BestPick</th>
                    <th>Consensus</th>
                    <th>Signal</th>
                    <th>Watch-out</th>
                  </tr>
                </thead>
                <tbody>
                  <% products.forEach((product) => { %>
                    <tr>
                      <td>#<%= product.rank %></td>
                      <td><a href="#<%= product.name.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "") %>"><%= product.name %></a></td>
                      <td><%= product.bestFor %></td>
                      <td><strong><%= product.bestPickScore %></strong></td>
                      <td><%= product.consensus %>%</td>
                      <td><%= product.signal %>/5</td>
                      <td><%= product.avoidIf %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </section>

          <% if (faqs?.length) { %>
          <section class="faq-section" aria-labelledby="faq-heading">
            <div class="section-kicker">Buying questions</div>
            <h2 id="faq-heading"><%= title %> FAQ</h2>
            <div class="faq-list">
              <% faqs.forEach((faq) => { %>
                <details>
                  <summary><%= faq.question %></summary>
                  <p><%= faq.answer %></p>
                </details>
              <% }) %>
            </div>
          </section>
          <% } %>

          <% if (finalRecommendation) { %>
          <section class="final-panel" aria-labelledby="final-heading">
            <div class="section-kicker">Final recommendation</div>
            <h2 id="final-heading">What most shoppers should do</h2>
            <p><%= finalRecommendation %></p>
          </section>
          <% } %>

          <% if (relatedReviews?.length) { %>
          <section class="comparison-section" aria-labelledby="related-heading">
            <div class="section-kicker">Related <%= section.title %> guides</div>
            <h2 id="related-heading">Keep comparing in <%= section.title %></h2>
            <p>Phavai groups related decisions together so you can move from this guide to adjacent products without losing the scoring context.</p>
            <div class="link-list">
              <a href="/<%= section.slug %>.html"><span>Back to <%= section.title %></span><span>Category hub</span></a>
              <% relatedReviews.slice(0, 5).forEach((review) => { %>
                <a href="/<%= review.slug %>.html"><span><%= review.title %></span><span>Review guide</span></a>
              <% }) %>
            </div>
          </section>
          <% } %>
        </div>

        <aside class="sidebar" aria-label="Ranking summary">
          <h2>Why this ranking is trustworthy</h2>
          <p>Phavai calculates BestPick from evidence items, rolls them into channel scores, then shows consensus and signal strength separately so confidence is not hidden inside a single number.</p>
          <form class="score-controls" data-score-controls>
            <h3>Adjust score rules</h3>
            <p>Move the sliders to recalculate this page. We normalize the active channels to 100%, then save your scoring preference on this device.</p>
            <% Object.entries(sourceWeights).forEach(([source, weight]) => { %>
              <label class="slider-row">
                <span><%= source %> <strong data-weight-label="<%= source %>"><%= weight %>%</strong></span>
                <input type="range" min="0" max="100" value="<%= weight %>" data-weight-input="<%= source %>" />
              </label>
            <% }) %>
            <div class="score-actions">
              <button class="button secondary" type="button" data-save-weights>Save my scoring preference</button>
              <button class="button secondary" type="button" data-reset-weights>Reset to Phavai default</button>
            </div>
            <p class="saved-note" data-save-note>Your scoring preference is saved in this browser and will be restored when you return.</p>
            <p class="ranking-note" data-ranking-note>Ranking matches the Phavai default.</p>
          </form>
          <p><%= sourceWeightReason %></p>
          <h3>Current ranking</h3>
          <% products.forEach((product) => { %>
            <div class="mini-rank" data-mini-rank="<%= product.name %>">
              <span>#<%= product.rank %> <%= product.name %></span>
              <strong><%= product.bestPickScore %></strong>
            </div>
          <% }) %>
          <p class="disclosure">Prototype note: this page uses a curated starter dataset verified against public review signals on April 20, 2026. The displayed BestPick and consensus values are generated at build time from the source scores.</p>
        </aside>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="footer-grid">
      <div>Phavai ranks products by evidence quality, not payout.</div>
      <div>
        <a href="/index.html">Home</a>
        <% allSections.forEach((item) => { %>
          <a href="/<%= item.slug %>.html"><%= item.title %></a>
        <% }) %>
        <a href="/methodology.html">Methodology</a>
        <a href="/about.html">About</a>
        <a href="/contact.html">Contact</a>
        <a href="/privacy.html">Privacy</a>
        <a href="/terms.html">Terms</a>
      </div>
    </div>
  </footer>
</body>
</html>
