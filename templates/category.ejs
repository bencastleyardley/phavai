<% const pageImage = image || products[0].image; %>
<% const ogImage = pageImage.startsWith("http") ? pageImage : `https://www.phavai.com${pageImage}`; %>
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= metaTitle || `${title} | Phavai` %></title>
  <meta name="description" content="<%= metaDescription || description %>" />
  <link rel="canonical" href="https://www.phavai.com/<%= slug %>.html" />
  <meta property="og:type" content="article" />
  <meta property="og:title" content="<%= metaTitle || `${title} | Phavai` %>" />
  <meta property="og:description" content="<%= metaDescription || description %>" />
  <meta property="og:image" content="<%= ogImage %>" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
  <script src="/score-controls.js" defer></script>
  <script type="application/ld+json">
  <%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": metaDescription || description,
    "image": ogImage,
    "dateModified": updated,
    "author": {
      "@type": "Organization",
      "name": "Phavai"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Phavai",
      "url": "https://www.phavai.com/"
    },
    "mainEntityOfPage": `https://www.phavai.com/${slug}.html`,
    "about": section.title,
    "mentions": products.map((product) => product.name)
  }, null, 2) %>
  </script>
  <script type="application/ld+json">
  <%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": schemaName,
    "description": description,
    "itemListElement": products.map((product) => ({
      "@type": "ListItem",
      "position": product.rank,
      "name": product.name,
      "url": `https://www.phavai.com/${slug}.html#${product.name.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "")}`
    }))
  }, null, 2) %>
  </script>
  <script type="application/ld+json">
  <%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://www.phavai.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": section.title,
        "item": `https://www.phavai.com/${section.slug}.html`
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": title,
        "item": `https://www.phavai.com/${slug}.html`
      }
    ]
  }, null, 2) %>
  </script>
  <% if (faqs?.length) { %>
  <script type="application/ld+json">
  <%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((faq) => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  }, null, 2) %>
  </script>
  <% } %>
</head>
<body>
  <header class="site-header">
    <nav class="nav" aria-label="Primary navigation">
      <a class="brand" href="/index.html"><span class="brand-mark">P</span> Phavai</a>
      <div class="nav-links">
        <% allSections.forEach((item) => { %>
          <a href="/<%= item.slug %>.html"><%= item.title %></a>
        <% }) %>
        <a class="hide-small" href="/methodology.html">Methodology</a>
      </div>
    </nav>
  </header>

  <main>
    <section class="page-hero">
      <div class="wrap">
        <a class="crumb" href="/<%= section.slug %>.html">Phavai / <%= section.title %> / <%= eyebrow %></a>
        <h1><%= title %></h1>
        <p class="lede">Shopping for <%= title.toLowerCase() %> gets messy fast. Phavai pulls together the best reviews and buyer feedback so the winner, tradeoffs, and proof are easier to see.</p>
        <div class="meta-row" aria-label="Page details">
          <span class="meta-pill">Last updated <%= updated %></span>
          <span class="meta-pill">Sources checked <%= sourcesVerifiedAt %></span>
          <span class="meta-pill"><%= audience %></span>
          <span class="meta-pill">Retail links never buy rank</span>
        </div>
        <div class="answer-panel" aria-label="Quick recommendation">
          <div>
            <span class="section-kicker">Best overall</span>
            <h2><%= products[0].name %></h2>
            <p><%= products[0].verdict %></p>
          </div>
          <div class="answer-grid">
            <div>
              <b>Buy it for</b>
              <p><%= products[0].bestFor %></p>
            </div>
            <div>
              <b>Skip it if</b>
              <p><%= products[0].avoidIf %></p>
            </div>
            <div>
              <b>Why trust the pick</b>
              <p>The best reviews, video context, and owner feedback point to the same practical pick.</p>
            </div>
          </div>
          <a class="button" href="#<%= products[0].name.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "") %>">Jump to the winner</a>
        </div>
      </div>
    </section>

    <section class="band">
      <div class="wrap ranking-layout">
        <div class="content-column">
          <p class="disclosure affiliate-disclosure">As an Amazon Associate, Phavai may earn from qualifying purchases. Retail links never change the order of our picks.</p>
          <div data-product-list>
          <% products.forEach((product) => { const id = product.name.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, ""); %>
            <article class="product" id="<%= id %>" data-product-name="<%= product.name %>" data-default-score="<%= product.bestPickScore %>" data-channel-scores='<%- JSON.stringify(Object.fromEntries(product.sourceScores.map((row) => [row.source, row.score]))) %>'>
              <div class="product-media">
                <img src="<%= product.image %>" alt="<%= product.imageAlt || product.name %>" width="500" height="500" loading="<%= product.rank === 1 ? 'eager' : 'lazy' %>" />
                <% if (product.imageInfo?.requiresAttribution) { %>
                  <p class="image-credit">
                    Image:
                    <% if (product.imageInfo.sourceUrl) { %><a href="<%= product.imageInfo.sourceUrl %>" target="_blank" rel="nofollow noopener"><%= product.imageInfo.credit %></a><% } else { %><%= product.imageInfo.credit %><% } %>
                    <% if (product.imageInfo.licenseUrl) { %> / <a href="<%= product.imageInfo.licenseUrl %>" target="_blank" rel="nofollow noopener"><%= product.imageInfo.license %></a><% } %>
                  </p>
                <% } %>
              </div>
              <div>
                <span class="rank-badge">Rank <span data-rank>#<%= product.rank %></span></span>
                <h2><%= product.name %></h2>
                <div class="tagline"><%= product.tag %></div>
                <p><%= product.verdict %></p>

                <div class="score-row" aria-label="Phavai score summary for <%= product.name %>">
                  <div class="score-box"><strong><%= product.bestPickScore %></strong><span>Pick score</span></div>
                  <div class="score-box subtle-score"><strong data-bestpick><%= product.bestPickScore %></strong><span>Custom score</span></div>
                  <div class="score-box"><strong data-consensus><%= product.consensus %>%</strong><span>Source agreement</span></div>
                  <div class="score-box"><strong><%= product.signal %>/5</strong><span>Evidence depth</span></div>
                </div>
                <p class="score-note">Based on <%= product.evidenceCount %> review and owner-feedback inputs. Custom score: <span data-raw-score><%= product.rawBestPickScore %></span>/100. Difference from the editorial default: <span data-score-delta>0</span>.</p>

                <div class="product-signal-grid" aria-label="Scoring signals for <%= product.name %>">
                  <% product.sourceScores.forEach((row) => { %>
                    <div class="product-signal">
                      <span><%= row.source %></span>
                      <strong><%= row.score %></strong>
                      <small><%= row.weight %>% weight</small>
                    </div>
                  <% }) %>
                </div>

                <ul class="spec-list" aria-label="Quick specs">
                  <% product.specs.forEach((spec) => { %>
                    <li><%= spec %></li>
                  <% }) %>
                </ul>

                <div class="source-table" aria-label="Score breakdown by evidence type">
                  <% product.sourceScores.forEach((row) => { const quickTier = product.evidenceSummary.tiers.find((tier) => tier.label === row.source); const quickLikeSources = quickTier?.likes.sources ?? []; const quickCautionSources = quickTier?.cautions.sources ?? []; const showQuickSources = quickTier && ["YouTube", "Reddit"].includes(row.source) && (quickLikeSources.length || quickCautionSources.length); %>
                    <div class="source-row">
                      <div>
                        <b><%= row.source %></b>
                        <small><%= row.weight %>% of default score</small>
                      </div>
                      <div>
                        <b><%= row.score %>/100</b>
                        <div class="meter" aria-hidden="true"><i style="--value:<%= row.score %>%"></i></div>
                      </div>
                      <div>
                        <b>What we saw</b>
                        <% if (row.topEvidence.is_public) { %>
                          <small><%= row.summary %> Best public source checked <%= row.topEvidence.verifiedAt %>: <%= row.topEvidence.title || row.topEvidence.sourceName %></small>
                        <% } else { %>
                          <small><%= row.summary %> Internal source checked <%= row.topEvidence.verifiedAt %>; not displayed publicly until an exact citation is curated.</small>
                        <% } %>
                      </div>
                      <% if (showQuickSources) { %>
                        <div class="quick-source-actions" aria-label="<%= row.source %> good and bad source links">
                          <% if (quickLikeSources.length) { %>
                            <details class="quick-source-drop">
                              <summary>Good</summary>
                              <div class="quick-source-body">
                                <p><%= quickTier.likes.interpretation %></p>
                                <% quickLikeSources.slice(0, 3).forEach((item) => { %>
                                  <a href="<%= item.url %>" target="_blank" rel="nofollow noopener">
                                    <span><%= item.publisher %></span>
                                    <b><%= item.title || item.sourceName %></b>
                                  </a>
                                <% }) %>
                              </div>
                            </details>
                          <% } %>
                          <% if (quickCautionSources.length) { %>
                            <details class="quick-source-drop caution">
                              <summary>Bad</summary>
                              <div class="quick-source-body">
                                <p><%= quickTier.cautions.interpretation %></p>
                                <% quickCautionSources.slice(0, 3).forEach((item) => { %>
                                  <a href="<%= item.url %>" target="_blank" rel="nofollow noopener">
                                    <span><%= item.publisher %></span>
                                    <b><%= item.title || item.sourceName %></b>
                                  </a>
                                <% }) %>
                              </div>
                            </details>
                          <% } %>
                        </div>
                      <% } else if (row.topEvidence.url && row.topEvidence.is_public) { %>
                        <a href="<%= row.topEvidence.url %>" target="_blank" rel="nofollow noopener">Read source</a>
                      <% } else { %>
                        <span class="source-placeholder">Internal note</span>
                      <% } %>
                    </div>
                  <% }) %>
                </div>

                <details class="source-accordion">
                  <summary>
                    <span>View sources</span>
                    <small>Expert, YouTube, and Reddit proof</small>
                  </summary>
                  <div class="source-tier-list">
                    <% product.evidenceSummary.tiers.forEach((tier, tierIndex) => { %>
                      <details class="source-tier" <%= tierIndex === 0 ? 'open' : '' %>>
                        <summary>
                          <span><%= tier.label %></span>
                          <small><%= tier.description %></small>
                        </summary>
                        <div class="source-tier-body <%= !tier.likes.sources.length || !tier.cautions.sources.length ? 'single-column' : '' %>">
                          <% if (tier.likes.sources.length) { %>
                          <section class="source-synthesis-panel like-panel">
                            <span class="source-section-label">What people like</span>
                            <p><%= tier.likes.interpretation %></p>
                            <div class="source-link-list">
                              <% tier.likes.sources.forEach((item, sourceIndex) => { %>
                                <a class="source-link <%= sourceIndex === 0 && item.is_primary_source ? 'best-source' : '' %>" href="<%= item.url %>" target="_blank" rel="nofollow noopener">
                                  <span><%= item.sourceLabel %><% if (sourceIndex === 0 && item.is_primary_source) { %> / Best evidence<% } %></span>
                                  <b><%= item.title || item.sourceName %></b>
                                  <small><%= item.publisher %><% if (item.author) { %> by <%= item.author %><% } %> - checked <%= item.verifiedAt %></small>
                                  <% if (item.evidence_note || item.summary) { %><em><%= item.evidence_note || item.summary %></em><% } %>
                                </a>
                              <% }) %>
                            </div>
                          </section>
                          <% } %>

                          <% if (tier.cautions.sources.length) { %>
                          <section class="source-synthesis-panel caution-panel">
                            <span class="source-section-label">What people caution</span>
                            <p><%= tier.cautions.interpretation %></p>
                            <div class="source-link-list">
                              <% tier.cautions.sources.forEach((item) => { %>
                                <a class="source-link" href="<%= item.url %>" target="_blank" rel="nofollow noopener">
                                  <span><%= item.sourceLabel %></span>
                                  <b><%= item.title || item.sourceName %></b>
                                  <small><%= item.publisher %><% if (item.author) { %> by <%= item.author %><% } %> - checked <%= item.verifiedAt %></small>
                                  <% if (item.evidence_note || item.summary) { %><em><%= item.evidence_note || item.summary %></em><% } %>
                                </a>
                              <% }) %>
                            </div>
                          </section>
                          <% } %>
                        </div>
                      </details>
                    <% }) %>
                  </div>
                  <% if (product.internalEvidenceCount > 0) { %>
                    <p class="source-governance-note"><%= product.internalEvidenceCount %> internal research notes stay out of the public drawer until they have exact, buyer-helpful URLs.</p>
                  <% } %>
                </details>

                <div class="editorial-callout">
                  <strong>Why it earned this spot</strong>
                  <p>This pick ranks here because the best available expert reviews come first, then video testing and owner discussion help confirm the practical tradeoffs. Specs are used to verify details, not to justify a win.</p>
                </div>

                <div class="two-col">
                  <div>
                    <h3>Best for</h3>
                    <p><%= product.bestFor %></p>
                    <h3>Avoid if</h3>
                    <p><%= product.avoidIf %></p>
                  </div>
                  <div>
                    <h3>Pros</h3>
                    <ul class="plain-list">
                      <% product.pros.forEach((pro) => { %><li><%= pro %></li><% }) %>
                    </ul>
                    <h3 style="margin-top:18px">Tradeoffs</h3>
                    <ul class="plain-list">
                      <% product.cons.forEach((con) => { %><li><%= con %></li><% }) %>
                    </ul>
                  </div>
                </div>

                <a class="button shopping-button" href="<%= product.affiliateUrl %>" target="_blank" rel="nofollow noopener sponsored">Check Amazon price</a>
              </div>
            </article>
          <% }) %>
          </div>

          <section class="comparison-section" aria-labelledby="comparison-heading">
            <div class="section-kicker">Compare quickly</div>
            <h2 id="comparison-heading">Top picks at a glance</h2>
            <p><%= comparisonIntro || "Use this table to compare the ranking, ideal buyer, confidence signals, and tradeoffs before opening the detailed evidence for each product." %></p>
            <div class="comparison-scroll">
              <table class="comparison-table">
                <thead>
                  <tr>
                    <th>Rank</th>
                    <th>Product</th>
                    <th>Best for</th>
                    <th>BestPick</th>
                    <th>Agreement</th>
                    <th>Evidence</th>
                    <th>Skip if</th>
                  </tr>
                </thead>
                <tbody>
                  <% products.forEach((product) => { %>
                    <tr>
                      <td>#<%= product.rank %></td>
                      <td><a href="#<%= product.name.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "") %>"><%= product.name %></a></td>
                      <td><%= product.bestFor %></td>
                      <td><strong><%= product.bestPickScore %></strong></td>
                      <td><%= product.consensus %>%</td>
                      <td><%= product.signal %>/5</td>
                      <td><%= product.avoidIf %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </section>

          <% if (faqs?.length) { %>
          <section class="faq-section" aria-labelledby="faq-heading">
            <div class="section-kicker">Buying questions</div>
            <h2 id="faq-heading"><%= title %> FAQ</h2>
            <div class="faq-list">
              <% faqs.forEach((faq) => { %>
                <details>
                  <summary><%= faq.question %></summary>
                  <p><%= faq.answer %></p>
                </details>
              <% }) %>
            </div>
          </section>
          <% } %>

          <% if (finalRecommendation) { %>
          <section class="final-panel" aria-labelledby="final-heading">
            <div class="section-kicker">Final recommendation</div>
            <h2 id="final-heading">What most shoppers should do</h2>
            <p><%= finalRecommendation %></p>
          </section>
          <% } %>

          <% if (relatedReviews?.length) { %>
          <section class="comparison-section" aria-labelledby="related-heading">
            <div class="section-kicker">Related <%= section.title %> guides</div>
            <h2 id="related-heading">Keep comparing in <%= section.title %></h2>
            <p>Most buying decisions are connected. These nearby guides help you compare the adjacent choice before you commit.</p>
            <div class="link-list">
              <a href="/<%= section.slug %>.html"><span>Back to <%= section.title %></span><span>Category hub</span></a>
              <% relatedReviews.slice(0, 5).forEach((review) => { %>
                <a href="/<%= review.slug %>.html"><span><%= review.title %></span><span>Review guide</span></a>
              <% }) %>
            </div>
          </section>
          <% } %>

          <% if (supportingPages?.length) { %>
          <section class="comparison-section" aria-labelledby="supporting-heading">
            <div class="section-kicker">Buying context</div>
            <h2 id="supporting-heading">Learn how to choose with confidence</h2>
            <p>Use these guides to understand the tradeoffs before you compare products: fit, features, durability, comfort, and the mistakes worth avoiding.</p>
            <div class="link-list">
              <% supportingPages.slice(0, 4).forEach((page) => { %>
                <a href="/<%= page.slug %>.html"><span><%= page.title %></span><span><%= page.type %></span></a>
              <% }) %>
            </div>
          </section>
          <% } %>
        </div>

        <aside class="sidebar" aria-label="Ranking summary">
          <h2>How to read this guide</h2>
          <p>The top pick is our editorial default. The page keeps the winner, tradeoffs, and best proof close together, so you can decide faster without treating the ranking as one-size-fits-all.</p>
          <form class="score-controls" data-score-controls>
            <h3>Tune the ranking</h3>
            <p>Care more about expert testing, video reviews, or owner feedback? Adjust the weighting and we will recalculate the page on this device.</p>
            <% Object.entries(sourceWeights).forEach(([source, weight]) => { %>
              <label class="slider-row">
                <span><%= source %> <strong data-weight-label="<%= source %>"><%= weight %>%</strong></span>
                <input type="range" min="0" max="100" value="<%= weight %>" data-weight-input="<%= source %>" />
              </label>
            <% }) %>
            <div class="score-actions">
              <button class="button secondary" type="button" data-save-weights>Save my preference</button>
              <button class="button secondary" type="button" data-reset-weights>Reset to editorial default</button>
            </div>
            <p class="saved-note" data-save-note>Your preference stays in this browser and can be reset any time.</p>
            <p class="ranking-note" data-ranking-note>Ranking matches the Phavai editorial default.</p>
          </form>
          <p><%= sourceWeightReason %></p>
          <h3>Current order</h3>
          <% products.forEach((product) => { %>
            <div class="mini-rank" data-mini-rank="<%= product.name %>">
              <span>#<%= product.rank %> <%= product.name %></span>
              <strong><%= product.bestPickScore %></strong>
            </div>
          <% }) %>
          <div class="editorial-card">
            <h3>Editorial standards</h3>
            <p>Phavai keeps shopping links separate from product order and shows the evidence behind each recommendation.</p>
            <a href="/editorial-standards.html">Read our standards</a>
          </div>
        </aside>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="footer-grid">
      <div>Phavai helps shoppers choose with evidence, plain tradeoffs, and independent ranking logic.</div>
      <div>
        <a href="/index.html">Home</a>
        <% allSections.forEach((item) => { %>
          <a href="/<%= item.slug %>.html"><%= item.title %></a>
        <% }) %>
        <a href="/methodology.html">Methodology</a>
        <a href="/about.html">About</a>
        <a href="/contact.html">Contact</a>
        <a href="/privacy.html">Privacy</a>
        <a href="/terms.html">Terms</a>
      </div>
    </div>
  </footer>
</body>
</html>
